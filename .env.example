# Random 64-char hex string used to sign session cookies.
# Generate with:  openssl rand -hex 32
SESSION_SECRET=replace-with-a-long-random-secret

# Only used for the seed-users script. Production accounts live in D1.
SEED_USER_1_USERNAME=you
SEED_USER_1_DISPLAY_NAME=You
SEED_USER_1_PASSWORD=change-me

SEED_USER_2_USERNAME=her
SEED_USER_2_DISPLAY_NAME=Her
SEED_USER_2_PASSWORD=change-me
