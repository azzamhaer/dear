{
  "name": "dear",
  "version": "0.1.0",
  "private": true,
  "description": "A private memories app — for us.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "pages:build": "npx @cloudflare/next-on-pages",
    "pages:dev": "npm run pages:build && wrangler pages dev .vercel/output/static --d1=DB --r2=MEDIA --compatibility-flag=nodejs_compat",
    "pages:deploy": "npm run pages:build && wrangler pages deploy .vercel/output/static",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply dear-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply dear-db --remote",
    "db:seed-users": "tsx --env-file=.env scripts/seed-users.ts"
  },
  "dependencies": {
    "@cloudflare/next-on-pages": "^1.13.5",
    "drizzle-orm": "^0.36.4",
    "framer-motion": "^11.11.17",
    "next": "^15.0.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241112.0",
    "@types/node": "^22.9.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "drizzle-kit": "^0.28.1",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.0.3",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vercel": "^37.14.0",
    "wrangler": "^3.86.1"
  }
}
