{
  "compilerOptions": {
    "target": "ES2022",
    "module": "esnext",
    "moduleResolution": "bundler",
    "jsx": "preserve",
    "noEmit": true,
    "strict": false,
    "noResolve": true,
    "skipLibCheck": true,
    "allowJs": true,
    "isolatedModules": true,
    "noImplicitUseStrict": true,
    "types": []
  }
}
