# Cloudflare Pages — native header config.
# This file is copied as-is to the build output and applied at the edge.

# Hashed Next.js static assets — safe to cache forever.
/_next/static/*
  Cache-Control: public, max-age=31536000, immutable

# Other static media (icons, manifest, etc.)
/icon.svg
  Cache-Control: public, max-age=86400, must-revalidate
/apple-icon.png
  Cache-Control: public, max-age=86400, must-revalidate
/favicon.svg
  Cache-Control: public, max-age=86400, must-revalidate
/manifest.webmanifest
  Cache-Control: public, max-age=3600, must-revalidate

# HTML / dynamic routes — never cache so the newest chunk hashes are
# always referenced after a deploy. (`/` and any path without a dot.)
/*
  Cache-Control: public, max-age=0, must-revalidate
